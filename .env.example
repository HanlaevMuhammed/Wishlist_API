HTTP_ADDR=:8080

# Postgres settings used by docker-compose
POSTGRES_USER=wishlist
POSTGRES_PASSWORD=wishlist
POSTGRES_DB=wishlist
POSTGRES_PORT=5432

# API settings
DATABASE_URL=postgres://wishlist:wishlist@postgres:5432/wishlist?sslmode=disable
JWT_SECRET=change-me-to-very-long-random-secret-at-least-32-chars
JWT_EXPIRATION_HOURS=168
MIGRATIONS_PATH=/app/migrations